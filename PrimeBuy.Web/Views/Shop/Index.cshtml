@{
    ViewData["Title"] = "Shop";
}

@section Styles {
    <link rel="stylesheet" href="~/css/shop.css">
}

<!-- ===== SHOP CONTENT ===== -->
<section class="section-padding">
    <div class="container">

        <!-- Breadcrumb -->
        <nav class="breadcrumb-nav mb-4">
            <a href="index.html">Home</a>
            <span class="separator">/</span>
            <span class="current">Shop</span>
        </nav>

        <!-- Mobile Filter Toggle -->
        <button class="filter-toggle-btn" id="filterToggle">
            <i class="bi bi-funnel"></i> Filters
        </button>

        <!-- Filter Overlay (mobile) -->
        <div class="filter-overlay" id="filterOverlay"></div>

        <div class="shop-layout" data-animate="fade-in">

            <!-- ===== LEFT FILTER SIDEBAR ===== -->
            <aside class="filter-sidebar" id="filterSidebar">

                <!-- Mobile close header (hidden on desktop) -->
                <div class="filter-close-btn d-lg-none">
                    <span>Filters</span>
                    <button id="filterClose"><i class="bi bi-x-lg"></i></button>
                </div>

                <!-- Category -->
                <div class="filter-group">
                    <div class="filter-group-title" data-toggle="filter">
                        Category <i class="bi bi-chevron-down"></i>
                    </div>
                    <ul class="filter-list filter-body">
                        <li><a href="#" class="active">Woman's Fashion <span class="count">(324)</span></a></li>
                        <li><a href="#">Men's Fashion <span class="count">(218)</span></a></li>
                        <li><a href="#">Electronics <span class="count">(156)</span></a></li>
                        <li><a href="#">Home & Lifestyle <span class="count">(89)</span></a></li>
                        <li><a href="#">Medicine <span class="count">(43)</span></a></li>
                        <li><a href="#">Sports & Outdoor <span class="count">(67)</span></a></li>
                        <li><a href="#">Baby's & Toys <span class="count">(92)</span></a></li>
                        <li><a href="#">Groceries & Pets <span class="count">(54)</span></a></li>
                        <li><a href="#">Health & Beauty <span class="count">(113)</span></a></li>
                    </ul>
                </div>

                <!-- Price Range -->
                <div class="filter-group">
                    <div class="filter-group-title" data-toggle="filter">
                        Price <i class="bi bi-chevron-down"></i>
                    </div>
                    <div class="price-range-wrapper filter-body">
                        <input type="range" class="price-slider" id="priceRange" min="0" max="2000" value="1500">
                        <div class="price-labels">
                            <span>$0</span>
                            <span id="priceValue">$1500</span>
                        </div>
                    </div>
                </div>

                <!-- Brand -->
                <div class="filter-group">
                    <div class="filter-group-title" data-toggle="filter">
                        Brand <i class="bi bi-chevron-down"></i>
                    </div>
                    <div class="filter-body">
                        <label class="filter-check"><input type="checkbox" checked> Samsung</label>
                        <label class="filter-check"><input type="checkbox"> Apple</label>
                        <label class="filter-check"><input type="checkbox"> Xiaomi</label>
                        <label class="filter-check"><input type="checkbox"> Sony</label>
                        <label class="filter-check"><input type="checkbox"> LG</label>
                        <label class="filter-check"><input type="checkbox"> HAVIT</label>
                    </div>
                </div>

                <!-- Colour -->
                <div class="filter-group">
                    <div class="filter-group-title" data-toggle="filter">
                        Colour <i class="bi bi-chevron-down"></i>
                    </div>
                    <div class="color-filter-list filter-body">
                        <span class="color-swatch active" style="background:#000;"></span>
                        <span class="color-swatch" style="background:#DB4444;"></span>
                        <span class="color-swatch" style="background:#FFAD33;"></span>
                        <span class="color-swatch" style="background:#00FF66;"></span>
                        <span class="color-swatch" style="background:#2F80ED;"></span>
                        <span class="color-swatch" style="background:#A259FF;"></span>
                        <span class="color-swatch" style="background:#E0E0E0;"></span>
                        <span class="color-swatch" style="background:#FF6F91;"></span>
                    </div>
                </div>

                <!-- Size -->
                <div class="filter-group">
                    <div class="filter-group-title" data-toggle="filter">
                        Size <i class="bi bi-chevron-down"></i>
                    </div>
                    <div class="filter-body">
                        <label class="filter-check"><input type="checkbox"> XS</label>
                        <label class="filter-check"><input type="checkbox" checked> S</label>
                        <label class="filter-check"><input type="checkbox" checked> M</label>
                        <label class="filter-check"><input type="checkbox"> L</label>
                        <label class="filter-check"><input type="checkbox"> XL</label>
                        <label class="filter-check"><input type="checkbox"> XXL</label>
                    </div>
                </div>

                <!-- Rating -->
                <div class="filter-group">
                    <div class="filter-group-title" data-toggle="filter">
                        Rating <i class="bi bi-chevron-down"></i>
                    </div>
                    <div class="filter-body">
                        <label class="rating-filter-item">
                            <input type="checkbox">
                            <span class="stars">
                                <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i>
                            </span>
                        </label>
                        <label class="rating-filter-item">
                            <input type="checkbox" checked>
                            <span class="stars">
                                <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star empty"></i>
                            </span>
                            & Up
                        </label>
                        <label class="rating-filter-item">
                            <input type="checkbox">
                            <span class="stars">
                                <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star empty"></i><i class="bi bi-star empty"></i>
                            </span>
                            & Up
                        </label>
                        <label class="rating-filter-item">
                            <input type="checkbox">
                            <span class="stars">
                                <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star empty"></i><i class="bi bi-star empty"></i><i class="bi bi-star empty"></i>
                            </span>
                            & Up
                        </label>
                    </div>
                </div>

                <!-- Apply -->
                <button class="btn-apply-filter" id="applyFilterBtn">Apply Filters</button>

            </aside>

            <!-- ===== RIGHT PRODUCTS AREA ===== -->
            <div class="products-area">

                <!-- Toolbar -->
                <div class="shop-toolbar">
                    <p class="shop-result-count mb-0">Showing <strong>1–12</strong> of <strong>156</strong> results</p>
                    <div class="shop-toolbar-right">
                        <div class="shop-sort">
                            <label>Sort by:</label>
                            <select id="sortSelect">
                                <option value="default">Default</option>
                                <option value="price-low">Price: Low to High</option>
                                <option value="price-high">Price: High to Low</option>
                                <option value="newest">Newest</option>
                                <option value="rating">Best Rating</option>
                                <option value="popular">Popularity</option>
                            </select>
                        </div>
                        <div class="view-toggle">
                            <button class="view-btn active" data-view="grid" title="Grid View"><i class="bi bi-grid-3x3-gap"></i></button>
                            <button class="view-btn" data-view="list" title="List View"><i class="bi bi-list-ul"></i></button>
                        </div>
                    </div>
                </div>

                <!-- Products Grid -->
                <div class="products-grid" id="productsGrid">

