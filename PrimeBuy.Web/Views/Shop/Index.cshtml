@model ShopVM

@{
    ViewData["Title"] = "Shop";
}

@section Styles {
    <link rel="stylesheet" href="~/css/shop.css">
}

<!-- ===== SHOP CONTENT ===== -->
<section class="section-padding">
    <div class="container">

        <!-- Breadcrumb -->
        <nav class="breadcrumb-nav mb-4">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <span class="separator">/</span>
            <span class="current">Shop</span>
        </nav>

        <!-- Mobile Filter Toggle -->
        <button class="filter-toggle-btn" id="filterToggle">
            <i class="bi bi-funnel"></i> Filters
        </button>

        <!-- Filter Overlay (mobile) -->
        <div class="filter-overlay" id="filterOverlay"></div>

        <div class="shop-layout" data-animate="fade-in">

            <!-- ===== LEFT FILTER SIDEBAR ===== -->
            <aside class="filter-sidebar" id="filterSidebar">

                <!-- Mobile close header (hidden on desktop) -->
                <div class="filter-close-btn d-lg-none">
                    <span>Filters</span>
                    <button id="filterClose"><i class="bi bi-x-lg"></i></button>
                </div>

                <!-- Category -->
                <div class="filter-group">
                    <div class="filter-group-title" data-toggle="filter">
                        Category <i class="bi bi-chevron-down"></i>
                    </div>
                    <ul class="filter-list filter-body">
                        <li><a href="#" onclick="loadCategory(null); return false;" class="@(Model.CategoryId == null ? "active" : "")" data-category-id="">All Products <span class="count">(@Model.TotalProductsCount)</span></a></li>
                        @foreach (var category in Model.ParentCategories)
                        {
                            var count = Model.CategoryProductCounts.ContainsKey(category.Id) ? Model.CategoryProductCounts[category.Id] : 0;
                            <li><a href="#" onclick="loadCategory(@category.Id); return false;" class="@(Model.CategoryId == category.Id ? "active" : "")" data-category-id="@category.Id">@category.Name <span class="count">(@count)</span></a></li>
                        }
                    </ul>
                </div>

            </aside>

            <!-- ===== RIGHT PRODUCTS AREA ===== -->
            <div class="products-area">

                <!-- Toolbar -->
                <div class="shop-toolbar">
                    <p class="shop-result-count mb-0">Showing <strong>@Model.StartItem–@Model.EndItem</strong> of <strong>@Model.TotalProductsCount</strong> results</p>
                    <div class="shop-toolbar-right">
                        <div class="shop-sort">
                            <label>Sort by:</label>
                            <select id="sortSelect" onchange="applySorting()">
                                <option value="default" selected="@(Model.SortBy == "default")">Default</option>
                                <option value="price-low" selected="@(Model.SortBy == "price-low")">Price: Low to High</option>
                                <option value="price-high" selected="@(Model.SortBy == "price-high")">Price: High to Low</option>
                                <option value="newest" selected="@(Model.SortBy == "newest")">Newest</option>
                                <option value="rating" selected="@(Model.SortBy == "rating")">Best Rating</option>
                                <option value="popular" selected="@(Model.SortBy == "popular")">Popularity</option>
                            </select>
                        </div>
                        <div class="view-toggle">
                            <button class="view-btn active" data-view="grid" title="Grid View"><i class="bi bi-grid-3x3-gap"></i></button>
                            <button class="view-btn" data-view="list" title="List View"><i class="bi bi-list-ul"></i></button>
                        </div>
                    </div>
                </div>

                <!-- Products Container -->
                <div id="productsContainer">
                    @await Html.PartialAsync("_ProductsListPartial", Model)
                </div>

                <!-- Loading Indicator -->
                <div id="loadingIndicator" style="display: none; text-align: center; padding: 20px;">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

@section PageJS {
    <script src="~/js/shop.js"></script>
    <script>
        // Current filter state
        let currentFilters = {
            categoryId: @(Model.CategoryId?.ToString() ?? "null"),
            searchTerm: '@Html.Raw(Model.SearchTerm ?? "")',
            sortBy: '@Model.SortBy'
        };

        // Load category products via AJAX
        function loadCategory(categoryId) {
            currentFilters.categoryId = categoryId;
            currentFilters.page = 1; // Reset to first page
            loadProducts(1);
            updateCategoryActiveState(categoryId);
        }

        // Load products with current filters
        function loadProducts(page = 1) {
            showLoading(true);
            
            const params = new URLSearchParams({
                page: page,
                pageSize: 12
            });
            
            // Add filters only if they have values
            if (currentFilters.categoryId !== null) params.append('categoryId', currentFilters.categoryId);
            if (currentFilters.searchTerm) params.append('searchTerm', currentFilters.searchTerm);
            if (currentFilters.sortBy) params.append('sortBy', currentFilters.sortBy);

            fetch(`@Url.Action("LoadProducts", "Shop")?${params.toString()}`, {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.text())
            .then(html => {
                document.getElementById('productsContainer').innerHTML = html;
                showLoading(false);
                updateUrl();
            })
            .catch(error => {
                console.error('Error loading products:', error);
                showLoading(false);
            });
        }

        // Update URL without page refresh
        function updateUrl() {
            const params = new URLSearchParams();
            
            if (currentFilters.categoryId !== null) params.append('categoryId', currentFilters.categoryId);
            if (currentFilters.searchTerm) params.append('searchTerm', currentFilters.searchTerm);
            if (currentFilters.sortBy && currentFilters.sortBy !== 'default') params.append('sortBy', currentFilters.sortBy);

            const newUrl = `${window.location.pathname}${params.toString() ? '?' + params.toString() : ''}`;
            window.history.pushState({}, '', newUrl);
        }

        // Update category active state
        function updateCategoryActiveState(categoryId) {
            document.querySelectorAll('.filter-list a').forEach(link => {
                link.classList.remove('active');
                const linkCategoryId = link.getAttribute('data-category-id');
                if ((categoryId === null && linkCategoryId === '') || 
                    (categoryId !== null && linkCategoryId == categoryId)) {
                    link.classList.add('active');
                }
            });
        }

        // Show/hide loading indicator
        function showLoading(show) {
            document.getElementById('loadingIndicator').style.display = show ? 'block' : 'none';
            document.getElementById('productsContainer').style.opacity = show ? '0.5' : '1';
        }

        // Apply sorting when dropdown changes
        function applySorting() {
            const sortValue = document.getElementById('sortSelect').value;
            currentFilters.sortBy = sortValue;
            loadProducts(1);
        }

        // Search functionality
        function performSearch() {
            const searchTerm = document.getElementById('searchInput').value;
            currentFilters.searchTerm = searchTerm;
            loadProducts(1);
        }
    </script>
}
