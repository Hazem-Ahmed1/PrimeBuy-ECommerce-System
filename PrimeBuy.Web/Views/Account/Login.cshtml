@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css">
}

<!-- ===== LOG IN SECTION ===== -->
<section class="auth-section">
    <div class="container-fluid p-0">
        <div class="row g-0 align-items-stretch" style="min-height: calc(100vh - 180px);">
            <!-- Left Image -->
            <div class="col-lg-6">
                <div class="auth-image-col h-100" data-animate="fade-left">
                    <img src="https://images.unsplash.com/photo-1607082349566-187342175e2f?w=800&h=700&fit=crop" alt="Shopping cart with phone">
                </div>
            </div>
            <!-- Right Form -->
            <div class="col-lg-6">
                <div class="auth-form-col h-100" data-animate="fade-right">
                    <div class="auth-form">
                        <h2>Log in to Exclusive</h2>
                        <p class="auth-subtitle">Enter your details below</p>

                        <form id="loginForm" novalidate>
                            <div class="input-group-auth">
                                <input type="text" class="form-input" placeholder="Email or Phone Number" required data-label="Email or Phone Number">
                                <span class="error-msg"><i class="bi bi-exclamation-circle"></i> <span></span></span>
                            </div>
                            <div class="input-group-auth">
                                <input type="password" class="form-input" placeholder="Password" required data-label="Password">
                                <span class="error-msg"><i class="bi bi-exclamation-circle"></i> <span></span></span>
                            </div>

                            <div class="d-flex align-items-center justify-content-between">
                                <button type="submit" class="btn-auth btn-auth-login">Log In</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
