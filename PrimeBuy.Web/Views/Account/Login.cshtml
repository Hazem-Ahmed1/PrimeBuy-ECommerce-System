@model LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css">
}

<!-- ===== LOG IN SECTION ===== -->
<section class="auth-section">
    <div class="container-fluid p-0">
        <div class="row g-0 align-items-stretch" style="min-height: calc(100vh - 180px);">
            <!-- Left Image -->
            <div class="col-lg-6">
                <div class="auth-image-col h-100" data-animate="fade-left">
                    <img src="https://images.unsplash.com/photo-1607082349566-187342175e2f?w=800&h=700&fit=crop" alt="Shopping cart with phone">
                </div>
            </div>
            <!-- Right Form -->
            <div class="col-lg-6">
                <div class="auth-form-col h-100" data-animate="fade-right">
                    <div class="auth-form">
                        <h2>Log in to PrimeBuy</h2>
                        <p class="auth-subtitle">Enter your details below</p>

                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <form asp-action="Login" method="post" class="auth-form-container">
                            <input asp-for="ReturnUrl" type="hidden" />
                            
                            <div class="input-group-auth">
                                <input asp-for="Email" class="form-input" placeholder="Email Address" />
                                <span asp-validation-for="Email" class="error-msg"><i class="bi bi-exclamation-circle"></i> <span></span></span>
                            </div>
                            
                            <div class="input-group-auth">
                                <input asp-for="Password" class="form-input" placeholder="Password" type="password" />
                                <span asp-validation-for="Password" class="error-msg"><i class="bi bi-exclamation-circle"></i> <span></span></span>
                            </div>

                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <div class="form-check">
                                    <input asp-for="RememberMe" class="form-check-input" />
                                    <label asp-for="RememberMe" class="form-check-label">
                                        Remember me
                                    </label>
                                </div>
                            </div>

                            <div class="d-flex align-items-center justify-content-between">
                                <button type="submit" class="btn-auth btn-auth-login">Log In</button>
                            </div>
                        </form>

                        <div class="text-center mt-4">
                            <p>Don't have an account? <a asp-action="Register" class="text-primary">Sign up here</a></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
