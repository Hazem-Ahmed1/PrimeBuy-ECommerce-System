@model EditAccountViewModel

@{
    ViewData["Title"] = "My Account";
}

@section Styles {
    <link rel="stylesheet" href="~/css/account.css">
}
<!-- ===== ACCOUNT PAGE CONTENT ===== -->
<section class="account-section section-padding">
    <div class="container">
        <!-- Breadcrumb -->
        <div class="d-flex justify-content-between align-items-center mb-5">
            <nav class="breadcrumb-nav">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <span class="separator">/</span>
                <span class="current">My Account</span>
            </nav>
            <p class="welcome-text mb-0">Welcome! <span class="text-danger">@Model.FirstName @Model.LastName</span></p>
        </div>

        <div class="row g-4">
            <!-- Sidebar Navigation -->
            <div class="col-lg-3">
                <div class="account-sidebar" data-animate="fade-left">
                    <h6 class="sidebar-title">Manage My Account</h6>
                    <ul class="sidebar-menu">
                        <li><a href="#" class="active">My Profile</a></li>
                    </ul>
                </div>
            </div>

            <!-- Profile Edit Form -->
            <div class="col-lg-9">
                <div class="profile-card" data-animate="fade-right">
                    <h5 class="profile-card-title">Edit Your Profile</h5>
                    
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show">
                            @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>
                    
                    <form asp-action="Index" method="post">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="form-field">
                                    <label asp-for="FirstName"></label>
                                    <input class="form-control" asp-for="FirstName">
                                    <span asp-validation-for="FirstName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-field">
                                    <label asp-for="MiddleName"></label>
                                    <input class="form-control" asp-for="MiddleName">
                                    <span asp-validation-for="MiddleName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-field">
                                    <label asp-for="LastName"></label>
                                    <input class="form-control" asp-for="LastName">
                                    <span asp-validation-for="LastName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-field">
                                    <label asp-for="Email"></label>
                                    <input class="form-control" asp-for="Email">
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-field">
                                    <label asp-for="PhoneNumber"></label>
                                    <input class="form-control" asp-for="PhoneNumber">
                                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Password Change -->
                        <div class="password-section mt-4">
                            <h6 class="password-title">Password Changes (Optional)</h6>
                            <p class="text-muted small">Leave blank to keep current password</p>
                            <div class="row g-4">
                                <div class="col-12">
                                    <div class="form-field">
                                        <label asp-for="OldPassword"></label>
                                        <input class="form-control" asp-for="OldPassword" placeholder="Enter current password">
                                        <span asp-validation-for="OldPassword" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="form-field">
                                        <label asp-for="Password"></label>
                                        <input class="form-control" asp-for="Password" placeholder="Enter new password">
                                        <span asp-validation-for="Password" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="form-field">
                                        <label asp-for="ConfirmPassword"></label>
                                        <input class="form-control" asp-for="ConfirmPassword" placeholder="Confirm new password">
                                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex justify-content-end align-items-center gap-3 mt-4">
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn-primary-custom">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
@section PageJS {
    <script src="~/js/account.js"></script>
    <partial name="_ValidationScriptsPartial" />
}
