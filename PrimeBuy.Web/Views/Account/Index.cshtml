@{
    ViewData["Title"] = "My Account";
}

@section Styles {
    <link rel="stylesheet" href="~/css/account.css">
}
<!-- ===== ACCOUNT PAGE CONTENT ===== -->
<section class="account-section section-padding">
    <div class="container">
        <!-- Breadcrumb -->
        <div class="d-flex justify-content-between align-items-center mb-5">
            <nav class="breadcrumb-nav">
                <a href="index.html">Home</a>
                <span class="separator">/</span>
                <span class="current">My Account</span>
            </nav>
            <p class="welcome-text mb-0">Welcome! <span class="text-danger">Md Rimel</span></p>
        </div>

        <div class="row g-4">
            <!-- Sidebar Navigation -->
            <div class="col-lg-3">
                <div class="account-sidebar" data-animate="fade-left">
                    <h6 class="sidebar-title">Manage My Account</h6>
                    <ul class="sidebar-menu">
                        <li><a href="#" class="active">My Profile</a></li>
                        <li><a href="#">Address Book</a></li>
                        <li><a href="#">My Payment Options</a></li>
                    </ul>

                    <h6 class="sidebar-title mt-4">My Orders</h6>
                    <ul class="sidebar-menu">
                        <li><a href="#">My Returns</a></li>
                        <li><a href="#">My Cancellations</a></li>
                    </ul>

                    <h6 class="sidebar-title mt-4">My WishList</h6>
                </div>
            </div>

            <!-- Profile Edit Form -->
            <div class="col-lg-9">
                <div class="profile-card" data-animate="fade-right">
                    <h5 class="profile-card-title">Edit Your Profile</h5>
                    <form id="profileForm">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div class="form-field">
                                    <label>First Name</label>
                                    <input type="text" class="form-control" value="Md" placeholder="First Name">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-field">
                                    <label>Last Name</label>
                                    <input type="text" class="form-control" value="Rimel" placeholder="Last Name">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-field">
                                    <label>Email</label>
                                    <input type="email" class="form-control" value="rimel1111@gmail.com" placeholder="Email">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-field">
                                    <label>Address</label>
                                    <input type="text" class="form-control" value="Kingston, 5236, United State" placeholder="Address">
                                </div>
                            </div>
                        </div>

                        <!-- Password Change -->
                        <div class="password-section mt-4">
                            <h6 class="password-title">Password Changes</h6>
                            <div class="row g-4">
                                <div class="col-12">
                                    <div class="form-field">
                                        <input type="password" class="form-control" placeholder="Current Password">
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="form-field">
                                        <input type="password" class="form-control" placeholder="New Password">
                                    </div>
                                </div>
                                <div class="col-12">
                                    <div class="form-field">
                                        <input type="password" class="form-control" placeholder="Confirm New Password">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex justify-content-end align-items-center gap-3 mt-4">
                            <button type="button" class="btn-cancel">Cancel</button>
                            <button type="submit" class="btn-primary-custom">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
@section PageJS {
    <script src="~/js/account.js"></script>
}
