@model RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css">
}

<section class="auth-section">
    <div class="container-fluid p-0">
        <div class="row g-0 align-items-stretch" style="min-height: calc(100vh - 180px);">
            <!-- Left Image -->
            <div class="col-lg-6">
                <div class="auth-image-col h-100" data-animate="fade-left">
                    <img src="https://images.unsplash.com/photo-1607082349566-187342175e2f?w=800&h=700&fit=crop" alt="Shopping cart with phone">
                </div>
            </div>
            <!-- Right Form -->
            <div class="col-lg-6">
                <div class="auth-form-col h-100" data-animate="fade-right">
                    <div class="auth-form">
                        <h2>Create an account</h2>
                        <p class="auth-subtitle">Enter your details below</p>

                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <form asp-action="Register" method="post" class="auth-form-container">
                            <div class="input-group-auth">
                                <input asp-for="FirstName" class="form-input" placeholder="First Name" />
                                <span asp-validation-for="FirstName" class="error-msg"><i class="bi bi-exclamation-circle"></i> <span></span></span>
                            </div>
                            
                            <div class="input-group-auth">
                                <input asp-for="MiddleName" class="form-input" placeholder="Middle Name" />
                                <span asp-validation-for="MiddleName" class="error-msg"><i class="bi bi-exclamation-circle"></i> <span></span></span>
                            </div>
                            
                            <div class="input-group-auth">
                                <input asp-for="LastName" class="form-input" placeholder="Last Name" />
                                <span asp-validation-for="LastName" class="error-msg"><i class="bi bi-exclamation-circle"></i> <span></span></span>
                            </div>
                            
                            <div class="input-group-auth">
                                <input asp-for="Email" class="form-input" placeholder="Email Address" />
                                <span asp-validation-for="Email" class="error-msg"><i class="bi bi-exclamation-circle"></i> <span></span></span>
                            </div>
                            
                            <div class="input-group-auth">
                                <input asp-for="Password" class="form-input" placeholder="Password" type="password" />
                                <span asp-validation-for="Password" class="error-msg"><i class="bi bi-exclamation-circle"></i> <span></span></span>
                            </div>
                            
                            <div class="input-group-auth">
                                <input asp-for="ConfirmPassword" class="form-input" placeholder="Confirm Password" type="password" />
                                <span asp-validation-for="ConfirmPassword" class="error-msg"><i class="bi bi-exclamation-circle"></i> <span></span></span>
                            </div>
                            
                            <div class="form-check mb-3">
                                <input asp-for="AgreeToTerms" class="form-check-input" />
                                <label asp-for="AgreeToTerms" class="form-check-label">
                                    I agree to the Terms & Conditions
                                </label>
                                <span asp-validation-for="AgreeToTerms" class="text-danger d-block"></span>
                            </div>

                            <button type="submit" class="btn-auth">Create Account</button>
                        </form>

                        <div class="auth-footer-link">
                            Already have account? <a asp-action="Login">Log in</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>