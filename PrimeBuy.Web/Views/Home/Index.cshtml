@model HomeVM
@{
    ViewData["Title"] = "Home";
}


@section Styles {
    <link rel="stylesheet" href="~/css/home.css">
}

<!-- ===== HERO SECTION WITH SIDEBAR ===== -->
<section class="hero-section" data-animate="fade-in">
    <div class="container">
        <div class="row">
            <!-- Sidebar Categories -->
            <div class="col-lg-3 d-none d-lg-block">
                <ul class="category-sidebar">

                    @foreach(var item in Model.ParentCategories)
                    {
                    <li> <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="@item.Id" >@item.Name</a></li>
                        
                    }
                </ul>
            </div>
            <!-- Hero Banner -->
            <div class="col-lg-9">
                <div id="heroCarousel" class="carousel slide hero-banner" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        <div class="carousel-item active">
                            <div class="hero-slide">
                                <div class="hero-content">
                                    <div class="d-flex align-items-center gap-3 mb-3">
                                        <i class="bi bi-apple fs-3"></i>
                                        <span>iPhone 14 Series</span>
                                    </div>
                                    <h1>Up to 10%<br>off Voucher</h1>
                                    <a href="#" class="hero-cta">
                                        Shop Now <i class="bi bi-arrow-right ms-2"></i>
                                    </a>
                                </div>
                                <div class="hero-image">
                                    <img src="https://images.unsplash.com/photo-1695048133142-1a20484d2569?w=600&h=400&fit=crop" alt="iPhone 14" class="img-fluid">
                                </div>
                            </div>
                        </div>
                        <div class="carousel-item">
                            <div class="hero-slide">
                                <div class="hero-content">
                                    <div class="d-flex align-items-center gap-3 mb-3">
                                        <i class="bi bi-laptop fs-3"></i>
                                        <span>MacBook Pro</span>
                                    </div>
                                    <h1>Up to 15%<br>off Voucher</h1>
                                    <a href="#" class="hero-cta">
                                        Shop Now <i class="bi bi-arrow-right ms-2"></i>
                                    </a>
                                </div>
                                <div class="hero-image">
                                    <img src="https://images.unsplash.com/photo-1517336714731-489689fd1ca8?w=600&h=400&fit=crop" alt="MacBook" class="img-fluid">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="carousel-indicators hero-indicators">
                        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
                        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== FLASH SALES ===== -->
<section class="flash-sales section-padding" data-animate="fade-in">
    <div class="container">
        <div class="section-label"><span class="label-marker"></span> Today's</div>
        <div class="section-header">
            <div class="d-flex align-items-end gap-5 flex-wrap">
                <h2 class="section-title mb-0">High Rate</h2>
                <div class="countdown" id="flashCountdown">
                    <div class="countdown-item">
                        <span class="count-label">Days</span>
                        <span class="count-value" id="days">03</span>
                    </div>
                    <span class="countdown-sep">:</span>
                    <div class="countdown-item">
                        <span class="count-label">Hours</span>
                        <span class="count-value" id="hours">23</span>
                    </div>
                    <span class="countdown-sep">:</span>
                    <div class="countdown-item">
                        <span class="count-label">Minutes</span>
                        <span class="count-value" id="minutes">19</span>
                    </div>
                    <span class="countdown-sep">:</span>
                    <div class="countdown-item">
                        <span class="count-label">Seconds</span>
                        <span class="count-value" id="seconds">56</span>
                    </div>
                </div>
            </div>
            <div class="nav-arrows">
                <button class="arrow-btn" id="flashPrev"><i class="bi bi-arrow-left"></i></button>
                <button class="arrow-btn" id="flashNext"><i class="bi bi-arrow-right"></i></button>
            </div>
        </div>

        <div class="product-slider-wrapper">
            <div class="product-slider" id="flashSlider">
                <!-- Product Card 1 -->


                @{
                    foreach (var item in Model.HighestRateProducts)
                    {
                        <div class="product-card">
                            <div class="product-image">
                                <span class="discount-badge">-40%</span>
                                <img src="@item.ProductImageUrl" alt="@item.Name">
                                <div class="product-actions">
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="shop-action-btn" title="View Details"><i class="bi bi-eye"></i></a>
                                </div>
                                <button class="add-to-cart-btn" onclick="addToCart(@item.Id)">Add To Cart</button>
                            </div>
                            <div class="product-info">
                                <h5 class="product-name">
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark">@item.Name</a>
                                </h5>
                                <div class="product-price">
                                    <span class="current-price">$@item.Price</span>
                                    <span class="old-price">$@((item.Price / (1 - 0.40m)).ToString("0.00"))</span>
                                </div>


                                <div class="product-rating">
                                    <div class="stars">

                                    @{
                                            int x = (int)item.Rating;
                                            for (int i = 0; i < x; i++)
                                            {
                                                <i class="bi bi-star-fill"></i>
                                            }
                                    }
                                    </div>
                                </div>
                            </div>
                        </div>

                    }
                }


            </div>
        </div>
    </div>
</section>

<hr class="container">

<!-- ===== BROWSE BY CATEGORY ===== -->
<section class="categories section-padding" data-animate="fade-in">
    <div class="container">
        <div class="section-label"><span class="label-marker"></span> Categories</div>
        <div class="section-header">
            <h2 class="section-title mb-0">Browse By Category</h2>
        </div>
        <div class="row g-4 mt-2">

            @{
                var firstCategories = Model.ParentCategories.Take(6);
            }
            @foreach (var item in firstCategories)
            {
                <div class="col-6 col-md-4 col-lg-2">
                    <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="@item.Id" class="text-decoration-none">
                        <div class="category-card">
                            <span>@item.Name</span>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
</section>

<hr class="container">

<!-- ===== BEST SELLING PRODUCTS ===== -->
<section class="best-selling section-padding" data-animate="fade-in">
    <div class="container">
        <div class="section-label"><span class="label-marker"></span> This Month</div>
        <div class="section-header">
            <h2 class="section-title mb-0">Best Selling Products</h2>
            <a href="#" class="btn btn-primary-custom">View All</a>
        </div>
        <div class="row g-4 mt-2">
            @foreach (var item in Model.BestSales)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="product-card">
                        <div class="product-image">
                            <img src="@item.ProductImageUrl" alt="@item.Name">
                            <div class="product-actions">
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="shop-action-btn" title="View Details"><i class="bi bi-eye"></i></a>
                            </div>
                            <button class="add-to-cart-btn" onclick="addToCart(@item.Id)">Add To Cart</button>
                        </div>
                        <div class="product-info">
                            <h5 class="product-name">
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-dark">@item.Name</a>
                            </h5>
                            <div class="product-price">
                                <span class="current-price">$@item.Price</span>
                            </div>
                            <div class="product-rating">
                                <div class="stars">
                                    

                                    @for(int i = 0; i < (int)item.Rating; i++)
                                    {
                                        <i class="bi bi-star-fill"></i>
                                    }
                                </div>
                                <span class="rating-count">@item.Rating</span>
                            </div>
                        </div>
                    </div>
                </div>

            }
        </div>
    </div>
</section>

<!-- ===== MUSIC EXPERIENCE BANNER ===== -->
<section class="music-banner section-padding" data-animate="fade-in">
    <div class="container">
        <div class="music-banner-inner">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <div class="music-content">
                        <span class="text-success fw-medium">Categories</span>
                        <h2>Enhance Your<br>Music Experience</h2>
                        <div class="banner-countdown">
                            <div class="banner-count-item">
                                <span class="bc-value">23</span>
                                <span class="bc-label">Hours</span>
                            </div>
                            <div class="banner-count-item">
                                <span class="bc-value">05</span>
                                <span class="bc-label">Days</span>
                            </div>
                            <div class="banner-count-item">
                                <span class="bc-value">59</span>
                                <span class="bc-label">Minutes</span>
                            </div>
                            <div class="banner-count-item">
                                <span class="bc-value">35</span>
                                <span class="bc-label">Seconds</span>
                            </div>
                        </div>
                        <a href="#" class="btn btn-success-custom mt-4">Buy Now!</a>
                    </div>
                </div>
                <div class="col-lg-6 text-center">
                    <div class="music-image">
                        <img src="https://images.unsplash.com/photo-1608043152269-423dbba4e7e1?w=500&h=400&fit=crop" alt="JBL Speaker" class="img-fluid">
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===== EXPLORE OUR PRODUCTS ===== -->
<section class="explore-products section-padding" data-animate="fade-in">
    <div class="container">
        <div class="section-label"><span class="label-marker"></span> Our Products</div>
        <div class="section-header">
            <h2 class="section-title mb-0">Explore Our Products</h2>
            <div class="nav-arrows">
                <button class="arrow-btn"><i class="bi bi-arrow-left"></i></button>
                <button class="arrow-btn"><i class="bi bi-arrow-right"></i></button>
            </div>
        </div>
        <!-- Row 1 -->
        <div class="row g-4 mt-2" id="products-container">

        </div>
        <div class="text-center mt-5">
            <a href="#" id="btnLoadMore" class= "btn-primary-custom">View More Products</a>
        </div>
    </div>
</section>

<!-- ===== SERVICES ===== -->
<section class="services section-padding" data-animate="fade-in">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="service-item">
                    <div class="service-icon">
                        <i class="bi bi-truck"></i>
                    </div>
                    <h5>FREE AND FAST DELIVERY</h5>
                    <p>Free delivery for all orders over $140</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="service-item">
                    <div class="service-icon">
                        <i class="bi bi-headset"></i>
                    </div>
                    <h5>24/7 CUSTOMER SERVICE</h5>
                    <p>Friendly 24/7 customer support</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="service-item">
                    <div class="service-icon">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h5>MONEY BACK GUARANTEE</h5>
                    <p>We return money within 30 days</p>
                </div>
            </div>
        </div>
    </div>
</section>

@section PageJS {
    <script src="~/js/home.js"></script>
}

<script>

   let page = 1;

   function loadData(){

         fetch(`/Home/LoadMoreProducts?page=${page}`)
         .then(res => res.text())
         .then(data => {
             document
             .getElementById("products-container")
             .insertAdjacentHTML('beforeend', data);
         });
   }
    loadData();
    document.getElementById('btnLoadMore').addEventListener('click', function(e) {

        e.preventDefault(); 
        page++;
        loadData();

    });
</script>