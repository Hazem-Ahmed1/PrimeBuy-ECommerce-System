@{
    ViewData["Title"] = "My Wishlist";
}

@section Styles {
    <link rel="stylesheet" href="~/css/wishlist.css">
}

<!-- ===== WISHLIST SECTION ===== -->
<section class="wishlist-section">
    <div class="container">

        <!-- Wishlist Header -->
        <div class="wishlist-header" data-animate="fade-in">
            <h2>Wishlist (<span id="wishlistCount">4</span>)</h2>
            <a href="#" class="btn-outline-custom">Move All To Bag</a>
        </div>

        <!-- Wishlist Grid -->
        <div class="row g-4" id="wishlistGrid" data-animate="fade-in">
            <!-- Card 1 -->
            <div class="col-6 col-md-4 col-lg-3">
                <div class="wishlist-card">
                    <div class="product-image">
                        <span class="discount-badge">-35%</span>
                        <button class="delete-btn" title="Remove"><i class="bi bi-trash3"></i></button>
                        <img src="https://images.unsplash.com/photo-1548036328-c9fa89d128fa?w=300&h=300&fit=crop" alt="Gucci duffle bag">
                    </div>
                    <button class="add-cart-bar"><i class="bi bi-cart3"></i> Add To Cart</button>
                    <div class="product-info">
                        <h5 class="product-name">Gucci duffle bag</h5>
                        <div class="product-price">
                            <span class="current-price">$960</span>
                            <span class="old-price">$1160</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card 2 -->
            <div class="col-6 col-md-4 col-lg-3">
                <div class="wishlist-card">
                    <div class="product-image">
                        <button class="delete-btn" title="Remove"><i class="bi bi-trash3"></i></button>
                        <img src="https://images.unsplash.com/photo-1587302912306-cf1ed9c33146?w=300&h=300&fit=crop" alt="RGB liquid CPU Cooler">
                    </div>
                    <button class="add-cart-bar"><i class="bi bi-cart3"></i> Add To Cart</button>
                    <div class="product-info">
                        <h5 class="product-name">RGB liquid CPU Cooler</h5>
                        <div class="product-price">
                            <span class="current-price">$1960</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card 3 -->
            <div class="col-6 col-md-4 col-lg-3">
                <div class="wishlist-card">
                    <div class="product-image">
                        <button class="delete-btn" title="Remove"><i class="bi bi-trash3"></i></button>
                        <img src="https://images.unsplash.com/photo-1612287230202-1ff1d85d1bdf?w=300&h=300&fit=crop" alt="GP11 Shooter USB Gamepad">
                    </div>
                    <button class="add-cart-bar"><i class="bi bi-cart3"></i> Add To Cart</button>
                    <div class="product-info">
                        <h5 class="product-name">GP11 Shooter USB Gamepad</h5>
                        <div class="product-price">
                            <span class="current-price">$550</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Card 4 -->
            <div class="col-6 col-md-4 col-lg-3">
                <div class="wishlist-card">
                    <div class="product-image">
                        <button class="delete-btn" title="Remove"><i class="bi bi-trash3"></i></button>
                        <img src="https://images.unsplash.com/photo-1551028719-00167b16eac5?w=300&h=300&fit=crop" alt="Quilted Satin Jacket">
                    </div>
                    <button class="add-cart-bar"><i class="bi bi-cart3"></i> Add To Cart</button>
                    <div class="product-info">
                        <h5 class="product-name">Quilted Satin Jacket</h5>
                        <div class="product-price">
                            <span class="current-price">$750</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ===== JUST FOR YOU ===== -->
        <div class="just-for-you" data-animate="fade-in">
            <div class="just-for-you-header">
                <div class="title-group">
                    <span class="label-marker"></span>
                    <h2>Just For You</h2>
                </div>
                <a href="#" class="btn-outline-custom">See All</a>
            </div>

            <div class="row g-4">
                <!-- Card 1 -->
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="wishlist-card">
                        <div class="product-image">
                            <span class="discount-badge">-35%</span>
                            <button class="eye-btn" title="Quick View"><i class="bi bi-eye"></i></button>
                            <img src="https://images.unsplash.com/photo-1496181133206-80ce9b88a853?w=300&h=300&fit=crop" alt="ASUS FHD Gaming Laptop">
                        </div>
                        <button class="add-cart-bar"><i class="bi bi-cart3"></i> Add To Cart</button>
                        <div class="product-info">
                            <h5 class="product-name">ASUS FHD Gaming Laptop</h5>
                            <div class="product-price">
                                <span class="current-price">$960</span>
                                <span class="old-price">$1160</span>
                            </div>
                            <div class="product-rating">
                                <div class="stars">
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                </div>
                                <span class="rating-count">(65)</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Card 2 -->
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="wishlist-card">
                        <div class="product-image">
                            <button class="eye-btn" title="Quick View"><i class="bi bi-eye"></i></button>
                            <img src="https://images.unsplash.com/photo-1527443224154-c4a3942d3acf?w=300&h=300&fit=crop" alt="IPS LCD Gaming Monitor">
                        </div>
                        <button class="add-cart-bar"><i class="bi bi-cart3"></i> Add To Cart</button>
                        <div class="product-info">
                            <h5 class="product-name">IPS LCD Gaming Monitor</h5>
                            <div class="product-price">
                                <span class="current-price">$1160</span>
                            </div>
                            <div class="product-rating">
                                <div class="stars">
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                </div>
                                <span class="rating-count">(65)</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Card 3 -->
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="wishlist-card">
                        <div class="product-image">
                            <span class="new-badge">NEW</span>
                            <button class="eye-btn" title="Quick View"><i class="bi bi-eye"></i></button>
                            <img src="https://images.unsplash.com/photo-1612287230202-1ff1d85d1bdf?w=300&h=300&fit=crop" alt="HAVIT HV-G92 Gamepad">
                        </div>
                        <button class="add-cart-bar"><i class="bi bi-cart3"></i> Add To Cart</button>
                        <div class="product-info">
                            <h5 class="product-name">HAVIT HV-G92 Gamepad</h5>
                            <div class="product-price">
                                <span class="current-price">$560</span>
                            </div>
                            <div class="product-rating">
                                <div class="stars">
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                </div>
                                <span class="rating-count">(65)</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Card 4 -->
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="wishlist-card">
                        <div class="product-image">
                            <button class="eye-btn" title="Quick View"><i class="bi bi-eye"></i></button>
                            <img src="https://images.unsplash.com/photo-1587829741301-dc798b83add3?w=300&h=300&fit=crop" alt="AK-900 Wired Keyboard">
                        </div>
                        <button class="add-cart-bar"><i class="bi bi-cart3"></i> Add To Cart</button>
                        <div class="product-info">
                            <h5 class="product-name">AK-900 Wired Keyboard</h5>
                            <div class="product-price">
                                <span class="current-price">$200</span>
                            </div>
                            <div class="product-rating">
                                <div class="stars">
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                </div>
                                <span class="rating-count">(65)</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>


@section PageJS {
    <script src="~/js/wishlist.js"></script>
}
