@{
    ViewData["Title"] = "About Us";
}

@section Styles {
    <link rel="stylesheet" href="~/css/about.css">
}


<section class="section-padding">
    <div class="container">

        <!-- Breadcrumb -->
        <nav class="breadcrumb-nav mb-5">
            <a href="index.html">Home</a>
            <span class="separator">/</span>
            <span class="current">About</span>
        </nav>

        <!-- Our Story -->
        <div class="story-section" data-animate="fade-in">
            <div class="story-text">
                <h2>Our Story</h2>
                <p>Launced in 2015, Exclusive is South Asia's premier online shopping makterpace with an active presense in Bangladesh. Supported by wide range of tailored marketing, data and service solutions, Exclusive has 10,500 sallers and 300 brands and serves 3 millioons customers across the region.</p>
                <p>Exclusive has more than 1 Million products to offer, growing at a very fast. Exclusive offers a diverse assotment in categories ranging from consumer.</p>
            </div>
            <div class="story-image">
                <img src="https://images.unsplash.com/photo-1607082349566-187342175e2f?w=600&h=400&fit=crop" alt="Shopping">
            </div>
        </div>

        <!-- Stats -->
        <div class="stats-grid" data-animate="fade-in">
            <div class="stat-card">
                <div class="stat-icon">
                    <div class="inner-circle">
                        <i class="bi bi-shop"></i>
                    </div>
                </div>
                <div class="stat-value">10.5k</div>
                <div class="stat-desc">Sallers active our site</div>
            </div>
            <div class="stat-card active">
                <div class="stat-icon">
                    <div class="inner-circle">
                        <i class="bi bi-currency-dollar"></i>
                    </div>
                </div>
                <div class="stat-value">33k</div>
                <div class="stat-desc">Mopnthly Produduct Sale</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">
                    <div class="inner-circle">
                        <i class="bi bi-bag-check"></i>
                    </div>
                </div>
                <div class="stat-value">45.5k</div>
                <div class="stat-desc">Customer active in our site</div>
            </div>
            <div class="stat-card">
                <div class="stat-icon">
                    <div class="inner-circle">
                        <i class="bi bi-coin"></i>
                    </div>
                </div>
                <div class="stat-value">25k</div>
                <div class="stat-desc">Anual gross sale in our site</div>
            </div>
        </div>

        <!-- Team -->
        <div class="team-section" data-animate="fade-in">
            <div class="team-grid">
                <div class="team-card">
                    <div class="team-card-image">
                        <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?w=400&h=500&fit=crop" alt="Tom Cruise">
                    </div>
                    <h4 class="team-name">Tom Cruise</h4>
                    <p class="team-role">Founder & Chairman</p>
                    <div class="team-socials">
                        <a href="#"><i class="bi bi-twitter"></i></a>
                        <a href="#"><i class="bi bi-instagram"></i></a>
                        <a href="#"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>
                <div class="team-card">
                    <div class="team-card-image">
                        <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=400&h=500&fit=crop" alt="Emma Watson">
                    </div>
                    <h4 class="team-name">Emma Watson</h4>
                    <p class="team-role">Managing Director</p>
                    <div class="team-socials">
                        <a href="#"><i class="bi bi-twitter"></i></a>
                        <a href="#"><i class="bi bi-instagram"></i></a>
                        <a href="#"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>
                <div class="team-card">
                    <div class="team-card-image">
                        <img src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=400&h=500&fit=crop" alt="Will Smith">
                    </div>
                    <h4 class="team-name">Will Smith</h4>
                    <p class="team-role">Product Designer</p>
                    <div class="team-socials">
                        <a href="#"><i class="bi bi-twitter"></i></a>
                        <a href="#"><i class="bi bi-instagram"></i></a>
                        <a href="#"><i class="bi bi-linkedin"></i></a>
                    </div>
                </div>
            </div>

            <!-- Carousel Dots -->
            <div class="team-dots">
                <button class="team-dot"></button>
                <button class="team-dot"></button>
                <button class="team-dot active"></button>
                <button class="team-dot"></button>
                <button class="team-dot"></button>
            </div>
        </div>

        <!-- Services -->
        <div class="about-services" data-animate="fade-in">
            <div class="about-service-item">
                <div class="about-service-icon">
                    <div class="inner-circle">
                        <i class="bi bi-truck"></i>
                    </div>
                </div>
                <h5>FREE AND FAST DELIVERY</h5>
                <p>Free delivery for all orders over $140</p>
            </div>
            <div class="about-service-item">
                <div class="about-service-icon">
                    <div class="inner-circle">
                        <i class="bi bi-headset"></i>
                    </div>
                </div>
                <h5>24/7 CUSTOMER SERVICE</h5>
                <p>Friendly 24/7 customer support</p>
            </div>
            <div class="about-service-item">
                <div class="about-service-icon">
                    <div class="inner-circle">
                        <i class="bi bi-shield-check"></i>
                    </div>
                </div>
                <h5>MONEY BACK GUARANTEE</h5>
                <p>We return money within 30 days</p>
            </div>
        </div>

    </div>
</section>