@model ProductDetailViewModel
@{
    ViewData["Title"] = $"{Model.Name} - Product Details";
}

@section Styles {
    <link rel="stylesheet" href="~/css/product.css">
}

<section class="section-padding">
    <div class="container">

        <!-- Breadcrumb -->
        <nav class="breadcrumb-nav mb-5">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <span class="separator">/</span>
            <a asp-controller="Shop" asp-action="Index">Shop</a>
            <span class="separator">/</span>
            <span class="current">@Model.Name</span>
        </nav>

        <div class="row">
            <!-- Gallery -->
            <div class="col-lg-7">
                <div class="gallery-wrapper" data-animate="fade-left">
                    <div class="gallery-thumbs">
                        <div class="thumb-item active" data-img="@Model.ProductImageUrl">
                            <img src="@Model.ProductImageUrl" alt="@Model.Name Thumbnail" style="width: 100px; height: 100px; object-fit: cover;">
                        </div>
                    </div>
                    <div class="gallery-main">
                        <img id="mainImage" src="@Model.ProductImageUrl" alt="@Model.Name" style="width: 100%; max-height: 500px; object-fit: cover;">
                    </div>
                </div>
            </div>

            <!-- Product Info -->
            <div class="col-lg-5">
                <div class="product-detail-info" data-animate="fade-right">
                    <h1 class="product-detail-title">@Model.Name</h1>
                    <div class="detail-rating">
                        <span class="stars">
                            @Html.Raw(Model.GetStarRating())
                        </span>
                        <span class="review-count">(@Model.GetReviewCount() Reviews)</span>
                        <span class="stock-status @(Model.IsInStock ? "in-stock" : "out-of-stock")">@Model.StockStatus</span>
                    </div>
                    <p class="detail-price">@Model.Price.ToString("C")</p>

                    <div class="product-meta mb-4">
                        <div class="meta-row">
                            <strong>SKU:</strong> @Model.SKU
                        </div>
                        <div class="meta-row">
                            <strong>Category:</strong> @Model.CategoryName
                        </div>
                        <div class="meta-row">
                            <strong>Stock:</strong> @Model.StockQuantity units available
                        </div>
                    </div>


                    <!-- Delivery Info -->
                    <div class="delivery-box">
                        <div class="delivery-item">
                            <i class="bi bi-truck delivery-icon"></i>
                            <div class="delivery-info">
                                <h6>Free Delivery</h6>
                                <p>Enter your postal code for Delivery Availability</p>
                            </div>
                        </div>
                        <div class="delivery-item">
                            <i class="bi bi-arrow-repeat delivery-icon"></i>
                            <div class="delivery-info">
                                <h6>Return Delivery</h6>
                                <p>Free 30 Days Delivery Returns.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>

@section PageJS {
    <script src="~/js/product.js"></script>
}
