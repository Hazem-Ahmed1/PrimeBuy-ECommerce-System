@model ProductDetailViewModel
@{
    ViewData["Title"] = $"{Model.Name} - Product Details";
}

@section Styles {
    <link rel="stylesheet" href="~/css/product.css">
}

<section class="section-padding">
    <div class="container">

        <!-- Breadcrumb -->
        <nav class="breadcrumb-nav mb-5">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <span class="separator">/</span>
            <a asp-controller="Shop" asp-action="Index">Shop</a>
            <span class="separator">/</span>
            <span class="current">@Model.Name</span>
        </nav>

        <div class="row">
            <!-- Gallery -->
            <div class="col-lg-7">
                <div class="gallery-wrapper" data-animate="fade-left">
                    <div class="gallery-thumbs">
                        <div class="thumb-item active" data-img="@Model.ProductImageUrl">
                            <img src="@Model.ProductImageUrl" alt="@Model.Name Thumbnail" style="width: 100px; height: 100px; object-fit: cover;">
                        </div>
                    </div>
                    <div class="gallery-main">
                        <img id="mainImage" src="@Model.ProductImageUrl" alt="@Model.Name" style="width: 100%; max-height: 500px; object-fit: cover;">
                    </div>
                </div>
            </div>

            <!-- Product Info -->
            <div class="col-lg-5">
                <div class="product-detail-info" data-animate="fade-right">
                    <h1 class="product-detail-title">@Model.Name</h1>
                    <div class="detail-rating">
                        <span class="stars">
                            @Html.Raw(Model.GetStarRating())
                        </span>
                        <span class="review-count">(@Model.GetReviewCount() Reviews)</span>
                        <span class="stock-status @(Model.IsInStock ? "in-stock" : "out-of-stock")">@Model.StockStatus</span>
                    </div>
                    <p class="detail-price">@Model.Price.ToString("C")</p>

                    <div class="product-meta mb-4">
                        <div class="meta-row">
                            <strong>SKU:</strong> @Model.SKU
                        </div>
                        <div class="meta-row">
                            <strong>Category:</strong> @Model.CategoryName
                        </div>
                        <div class="meta-row">
                            <strong>Stock:</strong> @Model.StockQuantity units available
                        </div>
                    </div>

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <!-- Add to Cart Section -->
                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="add-to-cart-section mb-4">
                            <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-flex gap-3 align-items-center">
                                <input type="hidden" name="productId" value="@Model.Id" />
                                <div class="quantity-selector" style="display: flex; align-items: center; border: 1px solid #ddd; border-radius: 4px;">
                                    <button type="button" class="qty-btn" onclick="decrementQty()" style="padding: 10px 15px; background: #f5f5f5; border: none; cursor: pointer;">
                                        <i class="bi bi-dash"></i>
                                    </button>
                                    <input type="number" id="quantityInput" name="quantity" value="1" min="1" max="@Model.StockQuantity"
                                           style="width: 60px; text-align: center; border: none; padding: 10px 5px;" readonly />
                                    <button type="button" class="qty-btn" onclick="incrementQty(@Model.StockQuantity)" style="padding: 10px 15px; background: #f5f5f5; border: none; cursor: pointer;">
                                        <i class="bi bi-plus"></i>
                                    </button>
                                </div>
                                @if (Model.IsInStock)
                                {
                                    <button type="submit" class="btn btn-danger flex-grow-1" style="padding: 12px 30px; font-weight: 600;">
                                        <i class="bi bi-cart-plus me-2"></i> Add to Cart
                                    </button>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-secondary flex-grow-1" disabled style="padding: 12px 30px; font-weight: 600;">
                                        <i class="bi bi-x-circle me-2"></i> Out of Stock
                                    </button>
                                }
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info mb-4">
                            <i class="bi bi-info-circle me-2"></i>
                            Please <a asp-controller="Account" asp-action="Login" class="alert-link">login</a> to add this product to your cart.
                        </div>
                    }

                    <!-- Delivery Info -->
                    <div class="delivery-box">
                        <div class="delivery-item">
                            <i class="bi bi-truck delivery-icon"></i>
                            <div class="delivery-info">
                                <h6>Free Delivery</h6>
                                <p>Enter your postal code for Delivery Availability</p>
                            </div>
                        </div>
                        <div class="delivery-item">
                            <i class="bi bi-arrow-repeat delivery-icon"></i>
                            <div class="delivery-info">
                                <h6>Return Delivery</h6>
                                <p>Free 30 Days Delivery Returns.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>

@section PageJS {
    <script src="~/js/product.js"></script>
    <script>
        function incrementQty(maxStock) {
            const input = document.getElementById('quantityInput');
            let currentValue = parseInt(input.value) || 1;
            if (currentValue < maxStock) {
                input.value = currentValue + 1;
            }
        }

        function decrementQty() {
            const input = document.getElementById('quantityInput');
            let currentValue = parseInt(input.value) || 1;
            if (currentValue > 1) {
                input.value = currentValue - 1;
            }
        }
    </script>
}
