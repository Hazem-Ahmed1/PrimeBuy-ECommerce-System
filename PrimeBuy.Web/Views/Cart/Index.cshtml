@model PrimeBuy.Domain.Models.Cart

@{
    ViewData["Title"] = "Shopping Cart";
}

@section Styles {
    <link rel="stylesheet" href="~/css/cart.css">
}

<section class="section-padding">
    <div class="container">

        <nav class="breadcrumb-nav mb-5">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <span class="separator">/</span>
            <span class="current">Cart</span>
        </nav>

        @if (!Model.CartItems.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-cart-x" style="font-size: 4rem; color: #ccc;"></i>
                <h4 class="mt-3">Your cart is empty</h4>
                <a asp-controller="Shop" asp-action="Index" class="btn btn-dark mt-3">Continue Shopping</a>
            </div>
        }
        else
        {
            <table class="cart-table" data-animate="fade-in">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th>Subtotal</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.CartItems)
                    {
                        <tr>
                            <td>
                                <div class="product-cell">
                                    <img src="@item.Product.ProductImageUrl" alt="@item.Product.Name" class="product-thumb" style="width:60px;height:60px;object-fit:cover;border-radius:4px;">
                                    <span class="product-name">@item.Product.Name</span>
                                </div>
                            </td>
                            <td>$@item.Product.Price.ToString("F2")</td>
                            <td>
                                <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" style="display:inline;">
                                    <input type="hidden" name="cartItemId" value="@item.Id" />
                                    <input type="number" name="quantity" class="qty-spinner" value="@item.Quantity" min="1" max="99" onchange="this.form.submit()">
                                </form>
                            </td>
                            <td>$@((item.Product.Price * item.Quantity).ToString("F2"))</td>
                            <td>
                                <form asp-controller="Cart" asp-action="Remove" method="post" style="display:inline;">
                                    <input type="hidden" name="cartItemId" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Remove"><i class="bi bi-x"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="coupon-total-row" data-animate="fade-in">
                <div class="cart-total-box">
                    <h5>Cart Total</h5>
                    <div class="total-row">
                        <span>Subtotal:</span>
                        <span>$@(Model.CartItems.Sum(ci => ci.Product.Price * ci.Quantity).ToString("F2"))</span>
                    </div>
                    <div class="total-row">
                        <span>Shipping:</span>
                        <span>Free</span>
                    </div>
                    <div class="total-row final">
                        <span>Total:</span>
                        <span>$@(Model.CartItems.Sum(ci => ci.Product.Price * ci.Quantity).ToString("F2"))</span>
                    </div>
                    <a asp-controller="Checkout" asp-action="Index" class="btn-checkout">Proceed to Checkout</a>
                </div>
            </div>
        }
    </div>
</section>
