@model PrimeBuy.Web.ViewModels.CartVM

@{
    ViewData["Title"] = "Shopping Cart";
}

@section Styles {
    <link rel="stylesheet" href="~/css/cart.css">
}

<section class="section-padding">
    <div class="container">

        <nav class="breadcrumb-nav mb-5">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <span class="separator">/</span>
            <span class="current">Cart</span>
        </nav>

        @if (!Model.Items.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-cart-x" style="font-size: 4rem; color: #ccc;"></i>
                <h4 class="mt-3">Your cart is empty</h4>
                <a asp-controller="Shop" asp-action="Index" class="btn btn-dark mt-3">Continue Shopping</a>
            </div>
        }
        else
        {
            <table class="cart-table" data-animate="fade-in">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th>Subtotal</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr data-cart-item-id="@item.CartItemId">
                            <td>
                                <div class="product-cell">
                                    <img src="@item.ProductImageUrl" alt="@item.ProductName" class="product-thumb" style="width:60px;height:60px;object-fit:cover;border-radius:4px;">
                                    <span class="product-name">@item.ProductName</span>
                                </div>
                            </td>
                            <td>$@item.Price.ToString("F2")</td>
                            <td>
                                <input type="number" class="qty-spinner" value="@item.Quantity" min="1" max="99"
                                       data-cart-item-id="@item.CartItemId"
                                       onchange="updateQuantity(this, @item.CartItemId)">
                            </td>
                            <td class="item-subtotal">$@item.Subtotal.ToString("F2")</td>
                            <td>
                                <form asp-controller="Cart" asp-action="Remove" method="post" style="display:inline;">
                                    <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Remove"><i class="bi bi-x"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="coupon-total-row" data-animate="fade-in">
                <div class="cart-total-box">
                    <h5>Cart Total</h5>
                    <div class="total-row">
                        <span>Subtotal:</span>
                        <span id="cart-subtotal">$@Model.Subtotal.ToString("F2")</span>
                    </div>
                    <div class="total-row">
                        <span>Shipping:</span>
                        <span>Free</span>
                    </div>
                    <div class="total-row final">
                        <span>Total:</span>
                        <span id="cart-total">$@Model.Total.ToString("F2")</span>
                    </div>
                    <a asp-controller="Checkout" asp-action="Index" class="btn-checkout">Proceed to Checkout</a>
                </div>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        function updateQuantity(input, cartItemId) {
            const quantity = parseInt(input.value);
            if (quantity < 1) { input.value = 1; return; }

            fetch('@Url.Action("UpdateQuantity", "Cart")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                },
                body: `cartItemId=${cartItemId}&quantity=${quantity}`
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    const row = document.querySelector(`tr[data-cart-item-id="${cartItemId}"]`);
                    if (row) {
                        row.querySelector('.item-subtotal').textContent = '$' + parseFloat(data.itemSubtotal).toFixed(2);
                    }
                    document.getElementById('cart-subtotal').textContent = '$' + parseFloat(data.cartSubtotal).toFixed(2);
                    document.getElementById('cart-total').textContent = '$' + parseFloat(data.cartTotal).toFixed(2);
                }
            });
        }
    </script>
}
