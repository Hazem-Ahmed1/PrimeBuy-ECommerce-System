@model IEnumerable<PrimeBuy.Web.ViewModels.OrderSummaryVM>

@{
    ViewData["Title"] = "My Orders";
}

@section Styles {
    <link rel="stylesheet" href="~/css/cart.css">
}

<section class="section-padding">
    <div class="container">
        <nav class="breadcrumb-nav mb-4">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <span class="separator">/</span>
            <span class="current">My Orders</span>
        </nav>

        <h3 class="mb-4">My Orders</h3>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-bag-x" style="font-size: 4rem; color: #ccc;"></i>
                <h4 class="mt-3">No orders yet</h4>
                <a asp-controller="Shop" asp-action="Index" class="btn btn-dark mt-3">Start Shopping</a>
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Order #</th>
                                <th>Date</th>
                                <th>Items</th>
                                <th>Total</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td><strong>@order.OrderNumber</strong></td>
                                    <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                    <td>@order.ItemCount item(s)</td>
                                    <td>$@order.TotalAmount.ToString("F2")</td>
                                    <td>
                                        @{
                                            var badgeClass = order.Status switch
                                            {
                                                PrimeBuy.Domain.Enums.OrderStatus.Pending => "bg-warning text-dark",
                                                PrimeBuy.Domain.Enums.OrderStatus.Paid => "bg-info",
                                                PrimeBuy.Domain.Enums.OrderStatus.Shipped => "bg-primary",
                                                PrimeBuy.Domain.Enums.OrderStatus.Completed => "bg-success",
                                                PrimeBuy.Domain.Enums.OrderStatus.Cancelled => "bg-danger",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeClass">@order.Status</span>
                                    </td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@order.OrderId" class="btn btn-sm btn-outline-dark">
                                            <i class="bi bi-eye"></i> Details
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</section>
