@model PrimeBuy.Web.ViewModels.CheckoutVM

@{
    ViewData["Title"] = "Checkout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/checkout.css">
}

<section class="breadcrumb-section">
    <div class="container">
        <div class="breadcrumb-nav">
            <a asp-controller="Home" asp-action="Index">Home</a> <span class="separator">/</span>
            <a asp-controller="Cart" asp-action="Index">Cart</a> <span class="separator">/</span>
            <span class="current">Checkout</span>
        </div>
    </div>
</section>

<section class="checkout-section">
    <div class="container">
        <div class="row">
            <div class="col-lg-6">
                <h2>Billing Details</h2>
                <form asp-controller="Checkout" asp-action="PlaceOrder" method="post" class="billing-form" data-animate="fade-left">
                    @Html.AntiForgeryToken()
                    <div>
                        <label>Country<span class="required">*</span></label>
                        <input type="text" asp-for="Country" class="form-field" required>
                        <span asp-validation-for="Country" class="text-danger"></span>
                    </div>
                    <div>
                        <label>City<span class="required">*</span></label>
                        <input type="text" asp-for="City" class="form-field" required>
                        <span asp-validation-for="City" class="text-danger"></span>
                    </div>
                    <div>
                        <label>Street Address<span class="required">*</span></label>
                        <input type="text" asp-for="Street" class="form-field" required>
                        <span asp-validation-for="Street" class="text-danger"></span>
                    </div>
                    <div>
                        <label>Zip Code<span class="required">*</span></label>
                        <input type="text" asp-for="ZipCode" class="form-field" required>
                        <span asp-validation-for="ZipCode" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn-place-order mt-4">Place Order</button>
                </form>
            </div>

            <div class="col-lg-5 offset-lg-1">
                <div class="order-summary" data-animate="fade-right">
                    @foreach (var item in Model.Items)
                    {
                        <div class="order-item">
                            <div class="order-item-left">
                                <img src="@item.ProductImageUrl" alt="@item.ProductName" style="width:50px;height:50px;object-fit:cover;border-radius:4px;">
                                <span>@item.ProductName x @item.Quantity</span>
                            </div>
                            <div class="order-item-right">$@item.Subtotal.ToString("F2")</div>
                        </div>
                    }

                    <div class="summary-row">
                        <span class="label">Subtotal:</span>
                        <span class="value">$@Model.Total.ToString("F2")</span>
                    </div>
                    <div class="summary-row">
                        <span class="label">Shipping:</span>
                        <span class="value">Free</span>
                    </div>
                    <div class="summary-row">
                        <span class="label">Total:</span>
                        <span class="value"><strong>$@Model.Total.ToString("F2")</strong></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
