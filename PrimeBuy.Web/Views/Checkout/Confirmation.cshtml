@{
    ViewData["Title"] = "Order Confirmed";
}

<section class="section-padding">
    <div class="container text-center py-5">
        <i class="bi bi-check-circle-fill text-success" style="font-size: 5rem;"></i>
        <h2 class="mt-3">Order Placed Successfully!</h2>
        <p class="text-muted mt-2">Your order #@ViewBag.OrderId has been placed. Thank you for shopping with us!</p>
        <a asp-controller="Shop" asp-action="Index" class="btn btn-dark mt-3">Continue Shopping</a>
    </div>
</section>
