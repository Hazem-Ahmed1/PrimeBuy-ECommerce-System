@model PrimeBuy.Domain.Models.Category

@{
    ViewData["Title"] = "Create Category";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>@TempData["Error"]</strong>
        @if (TempData["ErrorDetails"] != null)
        {
            <br><small>@TempData["ErrorDetails"]</small>
        }
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4>Create Category</h4>
    <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Name <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Parent Category</label>
                    <select asp-for="ParentCategoryId" asp-items="ViewBag.ParentCategories" class="form-select">
                        <option value="">None (Root Category)</option>
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label">Image URL</label>
                    <input asp-for="CategoryImage" class="form-control" placeholder="https://..." />
                </div>
            </div>
            <button type="submit" class="btn btn-danger mt-4"><i class="bi bi-plus-lg me-1"></i> Create Category</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
