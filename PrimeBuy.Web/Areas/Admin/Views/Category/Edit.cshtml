@model PrimeBuy.Domain.Models.Category

@{
    ViewData["Title"] = "Edit Category";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4>Edit Category</h4>
    <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Name <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Parent Category</label>
                    <select asp-for="ParentCategoryId" asp-items="ViewBag.ParentCategories" class="form-select">
                        <option value="">None (Root Category)</option>
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label">Image URL</label>
                    <input asp-for="CategoryImage" class="form-control" />
                </div>
            </div>
            <button type="submit" class="btn btn-danger mt-4"><i class="bi bi-check-lg me-1"></i> Save Changes</button>
        </form>
    </div>
</div>
