@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4>Products</h4>
    <a asp-area="Admin" asp-controller="Product" asp-action="Create" class="btn btn-danger">
        <i class="bi bi-plus-lg me-1"></i> Add Product
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Image</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Products will be loaded dynamically from backend -->
                <tr>
                    <td><img src="https://via.placeholder.com/50" class="rounded" alt="Product"></td>
                    <td>Sample Product</td>
                    <td>Electronics</td>
                    <td>$120.00</td>
                    <td><span class="badge bg-success">In Stock</span></td>
                    <td>
                        <a asp-area="Admin" asp-controller="Product" asp-action="Edit" asp-route-id="1" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-area="Admin" asp-controller="Product" asp-action="Delete" asp-route-id="1" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
