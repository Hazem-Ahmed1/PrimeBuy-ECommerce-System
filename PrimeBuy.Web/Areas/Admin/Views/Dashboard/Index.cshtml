@{
    ViewData["Title"] = "Dashboard";
}

<!-- Stats Cards -->
<div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                    <i class="bi bi-currency-dollar fs-4 text-primary"></i>
                </div>
                <div>
                    <small class="text-muted">Total Revenue</small>
                    <h5 class="mb-0">$45,231</h5>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                    <i class="bi bi-cart-check fs-4 text-success"></i>
                </div>
                <div>
                    <small class="text-muted">Total Orders</small>
                    <h5 class="mb-0">1,253</h5>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                    <i class="bi bi-box-seam fs-4 text-warning"></i>
                </div>
                <div>
                    <small class="text-muted">Products</small>
                    <h5 class="mb-0">384</h5>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-danger bg-opacity-10 p-3">
                    <i class="bi bi-people fs-4 text-danger"></i>
                </div>
                <div>
                    <small class="text-muted">Customers</small>
                    <h5 class="mb-0">8,412</h5>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Orders -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Recent Orders</h6>
        <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Order ID</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>#ORD-001</td>
                    <td>John Doe</td>
                    <td>Feb 28, 2026</td>
                    <td>$250.00</td>
                    <td><span class="badge bg-success">Completed</span></td>
                </tr>
                <tr>
                    <td>#ORD-002</td>
                    <td>Jane Smith</td>
                    <td>Feb 28, 2026</td>
                    <td>$180.00</td>
                    <td><span class="badge bg-warning text-dark">Pending</span></td>
                </tr>
                <tr>
                    <td>#ORD-003</td>
                    <td>Ahmed Ali</td>
                    <td>Feb 27, 2026</td>
                    <td>$420.00</td>
                    <td><span class="badge bg-info">Shipped</span></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
