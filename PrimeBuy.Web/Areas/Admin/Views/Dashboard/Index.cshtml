@{
    ViewData["Title"] = "Dashboard";
    var recentOrders = (IEnumerable<PrimeBuy.Domain.Models.Order>)ViewBag.RecentOrders;
}

<!-- Stats Cards -->
<div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                    <i class="bi bi-currency-dollar fs-4 text-primary"></i>
                </div>
                <div>
                    <small class="text-muted">Total Revenue</small>
                    <h5 class="mb-0">$@(((decimal)ViewBag.TotalRevenue).ToString("N2"))</h5>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3">
                    <i class="bi bi-cart-check fs-4 text-success"></i>
                </div>
                <div>
                    <small class="text-muted">Total Orders</small>
                    <h5 class="mb-0">@ViewBag.TotalOrders</h5>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                    <i class="bi bi-box-seam fs-4 text-warning"></i>
                </div>
                <div>
                    <small class="text-muted">Products</small>
                    <h5 class="mb-0">@ViewBag.TotalProducts</h5>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Orders -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Recent Orders</h6>
        <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="btn btn-sm btn-outline-primary">View All</a>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Order #</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in recentOrders)
                {
                    var badgeClass = order.Status switch
                    {
                        PrimeBuy.Domain.Enums.OrderStatus.Pending => "bg-warning text-dark",
                        PrimeBuy.Domain.Enums.OrderStatus.Paid => "bg-info",
                        PrimeBuy.Domain.Enums.OrderStatus.Shipped => "bg-primary",
                        PrimeBuy.Domain.Enums.OrderStatus.Completed => "bg-success",
                        PrimeBuy.Domain.Enums.OrderStatus.Cancelled => "bg-danger",
                        _ => "bg-secondary"
                    };
                    <tr>
                        <td>@order.OrderNumber</td>
                        <td>@order.ApplicationUser?.Email</td>
                        <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                        <td>$@order.TotalAmount.ToString("F2")</td>
                        <td><span class="badge @badgeClass">@order.Status</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
